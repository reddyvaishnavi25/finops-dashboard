# ---------------------------------------------------------------------------
# Aurora DSQL connection (LOCAL development only)
# ---------------------------------------------------------------------------
# On Vercel/v0 these are provided automatically via the integration + OIDC,
# so you do NOT need this file there. This is only for running the app or the
# migration/seed scripts locally (e.g. from VSCode).

# DSQL cluster endpoint, e.g. abcd1234.dsql.us-east-1.on.aws
PGHOST=
# AWS region your cluster lives in, e.g. us-east-1
AWS_REGION=
# Postgres user/db are fixed on DSQL
PGUSER=admin
PGDATABASE=postgres

# Credentials from the scoped IAM user created for local access.
# (Do NOT commit real values. These belong only in your local .env, which is gitignored.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
